rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // ⚠️ モック / デモ専用ルール
    // ===============================================================
    // このアプリは AuthGuard.tsx で localStorage ベースの
    // 「bypass認証」を使っており、Firebase Auth にはサインインしません。
    // よって Firestore アクセス時も request.auth == null のままで、
    // 「認証必須」のルールにすると全て permission-denied になります。
    //
    // そのため、デモ運用中は無条件許可に戻しています。
    // (Firebaseコンソールや .firebaserc の IP制限、
    //  Cloud Functionsゲートで代替セキュリティをかけてください)
    //
    // 本番運用させる際は以下を順に実施してください:
    // 1. AuthGuard.tsx の bypass モードを廃止し、Firebase Auth に統一
    // 2. このファイルを commit 7d18510 の内容に戻す
    //    (認証必須 + roleベースのadminチェック + 型バリデータ)
    // 3. tenantId を各コレクションに追加しテナント分離を実装
    // ===============================================================

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
